# Configuração Apache para Otimização de Performance
# Add estas configurações ao seu .htaccess ou vhost

# ===================================
# COMPRESSÃO GZIP/BROTLI
# ===================================
<IfModule mod_deflate.c>
  # Adicionar suporte para compressão
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
  
  # Especificar nível de compressão (1-9, 6 é bom balanço)
  DeflateCompressionLevel 6
  
  # Excluir certos tipos de arquivo (já comprimidos)
  SetEnvIfNoCase Request_URI \.(?:gif|jpe?g|png|rar|zip|webp)$ no-gzip dont-vary
  
  # Adicionar Vary header
  Header append Vary Accept-Encoding
</IfModule>

# ===================================
# CACHE HEADERS (Essencial!)
# ===================================

# HTML - Cache agressivo para versões, curto para index
<FilesMatch "\.(html)$">
  # Arquivos gerados com hash (bundle.xyzabc.js)
  <IfModule mod_headers.c>
    Header set Cache-Control "max-age=31536000, public, immutable"
  </IfModule>
</FilesMatch>

# CSS, JavaScript, Imagens - Cache agressivo (1 ano)
<FilesMatch "\.(js|css|webp|woff2|woff|ttf)$">
  <IfModule mod_headers.c>
    Header set Cache-Control "max-age=31536000, public, immutable"
  </IfModule>
</FilesMatch>

# Index.html - Sem cache (verificar sempre)
<FilesMatch "^index\.html$">
  <IfModule mod_headers.c>
    Header set Cache-Control "max-age=0, must-revalidate, no-cache, no-store"
    Header set Pragma "no-cache"
    Header set Expires "Wed, 11 Jan 1984 05:00:00 GMT"
  </IfModule>
</FilesMatch>

# ===================================
# HTTP/2 SERVER PUSH (Opcional)
# ===================================
# Ativar com: a2enmod http2

<IfModule mod_http2.c>
  # Habilitar HTTP/2
  Protocols h2 http/1.1
  
  # Server push para assets críticos
  # H2PushResource /assets/vendor-react-DAE9hRbm.js
  # H2PushResource /assets/index-PxQJc-5m.css
</IfModule>

# ===================================
# SECURITY HEADERS (Bonus)
# ===================================
<IfModule mod_headers.c>
  # Prevenir MIME type sniffing
  Header set X-Content-Type-Options "nosniff"
  
  # XSS Protection
  Header set X-XSS-Protection "1; mode=block"
  
  # Referrer Policy
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  
  # Permissions Policy
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# ===================================
# REWRITE RULES (SPA React)
# ===================================
<IfModule mod_rewrite.c>
  RewriteEngine On
  
  # Redirecionar para HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
  
  # Remove trailing slash (exceto diretórios)
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.*)/$ /$1 [L,R=301]
  
  # Servir arquivos/diretórios que existem como são
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]
  
  # Redirecionar tudo para index.html (SPA)
  RewriteRule ^ /index.html [QSA,L]
</IfModule>

# ===================================
# WEBP IMAGE FALLBACK
# ===================================
# Servir WebP automaticamente se suportado
<IfModule mod_rewrite.c>
  RewriteCond %{HTTP_ACCEPT} image/webp
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule (.+)\.(jpg|jpeg|png)$ $1.webp [T=image/webp,E=accept:1]
  
  <IfModule mod_headers.c>
    Header append Vary Accept env=accept
  </IfModule>
</IfModule>

