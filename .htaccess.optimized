# ===================================
# BROTLI (MAIS COMPRESSÃO)
# ===================================
# Se tiver mod_brotli instalado (melhor que gzip)

<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/xml text/css text/javascript application/javascript application/json font/woff font/woff2
  BrotliCompressionQuality 6
</IfModule>

# ===================================
